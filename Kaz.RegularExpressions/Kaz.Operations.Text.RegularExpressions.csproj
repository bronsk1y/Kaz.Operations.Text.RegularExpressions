<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
	<TargetFrameworks>net472;net8.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
	<LangVersion>latest</LangVersion>
  </PropertyGroup>

	<PropertyGroup>
		<PackageId>Kaz.Operations.Text.RegularExpressions</PackageId>
		<Version>1.0.2</Version>
		<Authors>Bronsk1y</Authors>
		<Description>
			Extends the working field for Kaz.Operations.Text by adding a fluent API builder for Regular Expressions.
		</Description>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageIcon>kaz-regularexpressions-icon.png</PackageIcon>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageTags>utility; string; text; regex; extension</PackageTags>
		<RepositoryUrl>https://github.com/bronsk1y/Kaz.Operations.Text.RegularExpressions</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<GenerateDocumentationFile>True</GenerateDocumentationFile>
	</PropertyGroup>

	<ItemGroup>
		<None Include="kaz-regularexpressions-icon.png" Pack="true" PackagePath="\" />
		<None Include="README.md" Pack="true" PackagePath="\" />
	</ItemGroup>

</Project>
